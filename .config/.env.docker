# Docker builds in parent directory (..), so use relative paths
# Building from root with: docker compose -f .config/docker/docker-compose.yml up

APP_ENV=development
DB_PASSWORD=jobpi_dev_password
DB_PORT=5432
API_PORT=8000
FRONTEND_PORT=3000

# App
SECRET_KEY=dev-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# AI
OPENROUTER_API_KEY=your_key_here
DSPY_MODEL=openrouter/meta-llama/llama-3-8b-instruct

# URLs
VITE_API_URL=http://localhost:8000
VITE_SITE_URL=http://localhost:3000
