APP_ENV=development
# ===== DATABASE =====
# Docker (recommended for local dev): PostgreSQL auto-configured
# DATABASE_URL=postgresql://jobpi_user:jobpi_dev_password@postgres:5432/jobpi_db
# Local fallback (SQLite): optional, auto-created
# DATABASE_URL=sqlite:///./jobpi.db
# Production (Supabase transaction pooler):
# DATABASE_URL=postgresql+psycopg://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SENTRY_DSN=
REDIS_URL=
DSPY_MODEL=openrouter/minimax/minimax-m2.5:free
DSPY_TEMPERATURE=0.2
MAX_OUTPUT_TOKENS=540
# Tune job-analysis generation budget (increase if outputs are too short, decrease for faster responses)
JOB_ANALYSIS_MAX_TOKENS=945
JOB_ANALYSIS_RETRY_MAX_TOKENS=608
# Target input size after job preprocessing (lower = fewer input tokens)
JOB_PREPROCESS_TARGET_CHARS=5000
AI_TIMEOUT_SECONDS=45

RATE_LIMIT_ENABLED=false
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_REGISTER_RATE_LIMIT=20
AUTH_LOGIN_RATE_LIMIT=30
JOB_ANALYZE_RATE_LIMIT_WINDOW_SECONDS=300
JOB_ANALYZE_RATE_LIMIT=30
MATCH_CVS_RATE_LIMIT_WINDOW_SECONDS=300
MATCH_CVS_RATE_LIMIT=30
COVER_LETTER_RATE_LIMIT_WINDOW_SECONDS=600
COVER_LETTER_RATE_LIMIT=6
CV_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=300
CV_UPLOAD_RATE_LIMIT=20

MAX_PDF_SIZE_MB=5
MAX_CVS_PER_UPLOAD=10
MAX_JOB_DESCRIPTION_CHARS=12000
MAX_CV_TEXT_CHARS=8000

SQLITE_TIMEOUT_SECONDS=30
TRUSTED_USER_EMAIL=
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
# Optional preview-domain pattern, for example:
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
CORS_ORIGIN_REGEX=
CORS_MAX_AGE_SECONDS=600

# ===== FRONTEND =====
# Optional in local development; frontend falls back to localhost and the hosted API.
VITE_API_URL=http://localhost:8000
# Reserved for canonical metadata and deploy-time site configuration.
VITE_SITE_URL=http://localhost:5173
